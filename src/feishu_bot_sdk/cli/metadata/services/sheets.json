            "spreadsheet_token": {
              "description": "电子表格的 token。可通过以下两种方式获取。了解更多，参考[电子表格概述](https://open.feishu.cn/document/ukTMukTMukTM/uATMzUjLwEzM14CMxMTN/overview)。;-  电子表格的 URL：https://sample.feishu.cn/sheets/==Iow7sNNEphp3WbtnbCscPqabcef==;- 调用[获取文件夹中的文件清单](https://open.feishu.cn/document/uAjLw4CM/ukTMukTMukTM/reference/drive-v1/file/list)",
              "example": "Iow7sNNEphp3WbtnbCscPqabcef",
              "type": "string",
              "location": "path",
              "required": true
            },
            "user_id_type": {
              "options": [
                {
                  "value": "user_id",
                  "description": "以user_id来识别用户"
                },
                {
                  "description": "以union_id来识别用户",
                  "value": "union_id"
                },
                {
                  "value": "open_id",
                  "description": "以open_id来识别用户"
                }
              ],
              "enumName": "GetSpreadsheetUserIDType",
              "type": "string",
              "location": "query",
              "required": false,
              "description": "此次调用中使用的用户ID的类型",
              "default": ""
            }
          },
          "responseBody": {
            "spreadsheet": {
              "ref": "get_spreadsheet",
              "properties": {
                "token": {
                  "annotations": [
                    "readOnly"
                  ],
                  "type": "string",
                  "description": "电子表格 token",
                  "required": false,
                  "example": "Iow7sNNEphp3WbtnbCscPqabcef"
                },
                "url": {
                  "type": "string",
                  "description": "电子表格的 URL 链接",
                  "required": false,
                  "example": "https://example.feishu.cn/sheets/Iow7sNNEphp3WbtnbCscPqabcef",
                  "annotations": [
                    "readOnly"
                  ]
                },
                "title": {
                  "type": "string",
                  "description": "电子表格标题",
                  "required": false,
                  "example": "title"
                },
                "owner_id": {
                  "required": false,
                  "example": "ou_48d0958ee4b2ab3eaf0b5f6c968abcef",
                  "annotations": [
                    "readOnly",
                    "open:x_user_id"
                  ],
                  "type": "string",
                  "description": "电子表格的所有者 ID。ID 类型由查询参数 user_id_type 决定。"
                }
              },
              "type": "object",
              "description": "电子表格的基础信息",
              "required": false
            }
          },
          "httpMethod": "GET"
        },
        "patch": {
          "danger": true,
          "docUrl": "https://open.feishu.cn/document/ukTMukTMukTM/uUDN04SN0QjL1QDN/sheets-v3/spreadsheet/patch",
          "parameterOrder": [
            "spreadsheet_token"
          ],
          "scopes": [
            "sheets:spreadsheet",
