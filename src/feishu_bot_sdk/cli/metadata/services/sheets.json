                  "example": "Iow7sNNEphp3WbtnbCscPqabcef",
                  "annotations": [
                    "readOnly"
                  ],
                  "type": "string"
                }
              },
              "type": "object",
              "description": "电子表格的基础信息",
              "required": false,
              "ref": "spreadsheet"
            }
          },
