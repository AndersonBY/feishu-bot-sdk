                  "type": "string"
                },
                "url": {
                  "required": false,
                  "example": "https://example.feishu.cn/sheets/Iow7sNNEphp3WbtnbCscPqabcef",
                  "annotations": [
                    "readOnly"
                  ],
                  "type": "string",
                  "description": "电子表格的 URL 链接"
                },
                "spreadsheet_token": {
                  "description": "电子表格 token",
